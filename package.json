{
  "name": "fix-or-trash",
  "private": true,
  "version": "18.18.0",
  "main": "electron/main.cjs",
  "author": "Antigravity User",
  "description": "Repair Shop Management Software",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:all": "npm run build && electron-builder --win --mac"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "@ghostery/adblocker-electron": "^2.14.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "~2.0.0",
    "@tauri-apps/plugin-updater": "~2.0.0",
    "cross-fetch": "^4.1.0",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "jimp": "^1.6.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.344.0",
    "png-to-ico": "^3.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.fixortrash.app",
    "productName": "FixOrTrash Pro",
    "files": [
      "dist-react/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName} Setup v${version}.exe",
      "icon": "correct_icon.ico",
      "verifyUpdateCodeSignature": false,
      "sign": null
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FixOrTrash Pro"
    },
    "extraResources": [
      "./resources/**"
    ]
  }
}